# ===================================================================
# Dependencies (для кореня, client/ та server/)
# ===================================================================
node_modules/


# ===================================================================
# Environment & Secret files
# Застосовується до всіх .env файлів у будь-якій папці
# ===================================================================
.env
.env.*
!.env.example


# ===================================================================
# Server Specific (Node.js & Prisma)
# ===================================================================
# Ігноруємо папку з автозгенерованим клієнтом Prisma, ДЕ Б ВОНА НЕ БУЛА
# Знак ** означає "в будь-якій підпапці"
**/generated

# SQLite файли, якщо використовуєш Prisma з SQLite для локальної розробки
server/prisma/dev.db
server/prisma/dev.db-journal


# ===================================================================
# Client Specific (React, Vue, Next.js, etc.)
# ===================================================================
# Папки збірки клієнтського додатку
client/build/
client/dist/

# Для Next.js
client/.next/

# Для Vite
client/.vite/


# ===================================================================
# General (Логи, кеш, IDE, OS)
# ===================================================================
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage reports
coverage/

# OS generated files
.DS_Store
Thumbs.db

# IDE config
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Cache
.cache/
.npm/
.yarn/